# Miscellaneous
*.class
*.log
*.pyc
*.swp

# Environment / secrets (do NOT commit — copy env.json.example → env.json and fill in values)
env.json

# Dart obfuscation debug symbols — keep private, needed for crash symbolication
build/debug-info/
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
/android/key.properties

# Ignore large workspace patch artifacts
patches/core_commits/*.patch
# Local/generated artifacts
.DS_Store
.dart_tool/
build/
ios/Pods/
macos/Pods/
out.apks
out_apks_dir/
bundletool-all-*.jar
android/local.properties
__MACOSX/

# Supabase CLI local state (project ref, linked project, API version cache)
# These are machine-specific and must not be committed.
supabase/.temp/

# SonarQube local scan workspace (generated analysis artifacts)
.scannerwork/

# VS Code C/C++ extension — machine-specific include paths, auto-generated
.vscode/c_cpp_properties.json

# Local device preference written by `flutter run`
device.json

# Developer scratch / TODO notes (not part of the codebase)
.todo_*.md

+  bool _canSubmit(TellerVm vm, TellerSchoolRow? row) {
+    // Require a selected teacher for both deposit and withdrawal
+    if (_selectedTeacherId == null) return false;
+    if (_recordingWithdrawal) {
+      final n = double.tryParse(_payoutAmountCtrl.text) ?? 0;
+      final balance = row?.accountBalance ?? double.infinity;
+      return n > 0 && n <= balance;
+    }
+    final n = double.tryParse(_fundsCtrl.text.replaceAll(',', '')) ?? 0;
+    return n > 0;
+  }
 
   String _formatMoney(double n) => '\$${n.toStringAsFixed(2)}';
